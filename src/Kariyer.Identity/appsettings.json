{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Yarp.ReverseProxy": "Information",
        "MassTransit": "Information",
        "System": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "ExternalProvider": {
    "Url": "",
    "JwtSecret": ""
  },
  "RabbitMQ": {
    "Host": "",
    "Username": "",
    "Password": ""
  },
  "SupabaseSettings": {
      "Url": "https://placeholder.supabase.co",
      "HostName": "placeholder.supabase.co"
    },
  "ReverseProxy": {
    "Routes": {
      "supabaseAuthRoute": {
        "ClusterId": "supabaseCluster",
        "Order": 1,
        "Match": {
          "Path": "/auth/v1/{**catch-all}"
        },
        "Transforms": [{ "RequestHeader": "Host", "Set": "{SupabaseSettings:HostName}" }]
      },
      "nodeBackendRoute": {
        "ClusterId": "nodeBackendCluster",
        "Order": 2,
        "Match": {
          "Path": "/{**catch-all}",
          "Headers": [
            {
              "Name": "X-Proxy-To-Node",
              "Values": [ "true" ],
              "Mode": "ExactHeader"
            }
          ]
        }
      }
    },
    "Clusters": {
      "supabaseCluster": {
        "Destinations": {
          "supabase": {
            "Address": "{SupabaseSettings:Url}"
          }
        }
      },
      "nodeBackendCluster": {
        "Destinations": {
          "nodeApp": {
            "Address": "http://127.0.0.1:3031"
          }
        }
      }
    }
  }
}
